@model AgenceLocationVoiture.Helpers.PaginatedList<AgenceLocationVoiture.Models.OffreLoc>
@{
    ViewData["Title"] = "Les Offres de location";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-md-12 text-center">
            <h1><i class="fas fa-tag"></i> Toutes nos offres de location</h1>
            <p class="lead">Découvrez notre sélection de véhicules disponibles</p>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Ville</label>
                        <input type="text" name="ville" class="form-control" placeholder="Tunis, Djerba..." value="@ViewBag.CurrentVille" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Date de début</label>
                        <input type="date" name="dateDebut" class="form-control" value="@ViewBag.CurrentDateDebut" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Date de fin</label>
                        <input type="date" name="dateFin" class="form-control" value="@ViewBag.CurrentDateFin" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">&nbsp;</label>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-search"></i> Rechercher
                        </button>
                    </div>
                </div>
                <div class="text-center mt-3">
                    <a asp-action="Search" class="btn btn-link">
                        <i class="fas fa-sliders-h"></i> Recherche avancée avec plus de critères
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="mb-3 d-flex justify-content-between align-items-center">
            <p class="text-muted mb-0">
                <i class="fas fa-info-circle"></i> @Model.TotalItems offre(s) disponible(s)
                @if (!string.IsNullOrEmpty(ViewBag.CurrentVille))
                {
                    <text> à @ViewBag.CurrentVille</text>
                }
                <br />
                <small>Page @Model.PageIndex sur @Model.TotalPages</small>
            </p>
        </div>

        <div class="row">
            @foreach (var offre in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(offre.Voiture?.PhotoPrincipaleUrl))
                        {
                            <img src="@offre.Voiture.PhotoPrincipaleUrl" class="card-img-top" alt="@offre.Titre" 
                                 style="height: 200px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="fas fa-car fa-5x text-muted"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@offre.Titre</h5>
                            <p class="card-text text-muted">
                                @if (offre.Description != null && offre.Description.Length > 100)
                                {
                                    @offre.Description.Substring(0, 100)<text>...</text>
                                }
                                else
                                {
                                    @offre.Description
                                }
                            </p>
                            
                            <div class="mb-2">
                                <small class="text-muted">
                                    <i class="fas fa-calendar-alt"></i> Disponible du <strong>@offre.DateDebut.ToString("dd/MM/yyyy")</strong> au <strong>@offre.DateFin.ToString("dd/MM/yyyy")</strong> <br />
                                    <i class="fas fa-car"></i> @offre.Voiture?.Marque @offre.Voiture?.Modele<br />
                                    <i class="fas fa-building"></i> @offre.Agence?.NomAgence<br />
                                    <i class="fas fa-map-marker-alt"></i> @offre.Agence?.Ville
                                </small>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="h4 text-primary mb-0">@offre.PrixParJour</span>
                                    <small class="text-muted">TND/jour</small>
                                </div>
                                <a asp-action="Details" asp-route-id="@offre.Id" class="btn btn-primary">
                                    Voir détails
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 0)
        {
            <nav aria-label="Pagination des offres" class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" 
                           href="@Url.Action("Index", new { 
                               pageNumber = Model.PageIndex - 1,
                               ville = ViewBag.CurrentVille,
                               dateDebut = ViewBag.CurrentDateDebut,
                               dateFin = ViewBag.CurrentDateFin
                           })"
                           aria-label="Précédent">
                            <i class="fas fa-chevron-left"></i> Précédent
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == 1 || i == Model.TotalPages || (i >= Model.PageIndex - 2 && i <= Model.PageIndex + 2))
                        {
                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                <a class="page-link" 
                                
                                   href="@Url.Action("Index", new { 
                                       pageNumber = i,
                                       ville = ViewBag.CurrentVille,
                                       dateDebut = ViewBag.CurrentDateDebut,
                                       dateFin = ViewBag.CurrentDateFin
                                   })">
                                    @i
                                </a>
                            </li>
                        }
                        else if (i == Model.PageIndex - 3 || i == Model.PageIndex + 3)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        }
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" 
                           href="@Url.Action("Index", new { 
                               pageNumber = Model.PageIndex + 1,
                               ville = ViewBag.CurrentVille,
                               dateDebut = ViewBag.CurrentDateDebut,
                               dateFin = ViewBag.CurrentDateFin
                           })"
                           aria-label="Suivant">
                            Suivant <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-info-circle fa-3x mb-3"></i>
            <h4>Aucune offre disponible</h4>
            <p>Revenez plus tard ou essayez avec d'autres critères.</p>
            <a asp-action="Search" class="btn btn-primary mt-3">
                <i class="fas fa-sliders-h"></i> Recherche avancée
            </a>
        </div>
    }
</div>

