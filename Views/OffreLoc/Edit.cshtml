@model AgenceLocationVoiture.ViewModels.OffreLocViewModel
@{
    ViewData["Title"] = "Modifier l'offre";
    var voitures = ViewBag.Voitures as IEnumerable<AgenceLocationVoiture.Models.Voiture>;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0"><i class="fas fa-edit"></i> Modifier l'offre de location</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="AgenceId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <h5 class="mb-3"><i class="fas fa-car"></i> SÈlection du vÈhicule</h5>
                        <div class="mb-4">
                            <label asp-for="VoitureId" class="form-label">VÈhicule *</label>
                            <select asp-for="VoitureId" class="form-select">
                                <option value="">-- SÈlectionner un vÈhicule --</option>
                                @if (voitures != null)
                                {
                                    @foreach (var voiture in voitures)
                                    {
                                        <option value="@voiture.Id" selected="@(voiture.Id == Model.VoitureId)">
                                            @voiture.Marque @voiture.Modele (@voiture.Annee) - @voiture.Immatriculation
                                        </option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="VoitureId" class="text-danger"></span>
                        </div>

                        <h5 class="mb-3"><i class="fas fa-info-circle"></i> Informations de l'offre</h5>
                        <div class="mb-3">
                            <label asp-for="Titre" class="form-label">Titre *</label>
                            <input asp-for="Titre" class="form-control" placeholder="Ex: Location Renault Clio - IdÈale ville" />
                            <span asp-validation-for="Titre" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description *</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="DÈcrivez votre offre..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <h5 class="mb-3"><i class="fas fa-euro-sign"></i> Tarification</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PrixParJour" class="form-label">Prix par jour * (TND)</label>
                                <input asp-for="PrixParJour" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="PrixParJour" class="text-danger"></span>
                            </div>
                           
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="CautionMontant" class="form-label">Montant de la caution (TND)</label>
                                <input asp-for="CautionMontant" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="CautionMontant" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="FraisLivraison" class="form-label">Frais de livraison (TND)</label>
                                <input asp-for="FraisLivraison" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="FraisLivraison" class="text-danger"></span>
                            </div>
                        </div>

                        <h5 class="mb-3"><i class="fas fa-road"></i> KilomÈtrage</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="KilometrageInclus" class="form-label">Km inclus par jour *</label>
                                <input asp-for="KilometrageInclus" type="number" class="form-control" />
                                <span asp-validation-for="KilometrageInclus" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="FraisKmSupplementaire" class="form-label">Frais km sup. (TND/km)</label>
                                <input asp-for="FraisKmSupplementaire" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="FraisKmSupplementaire" class="text-danger"></span>
                            </div>
                        </div>

                        <h5 class="mb-3"><i class="fas fa-user-check"></i> Conditions</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="AgeMinimumConducteur" class="form-label">¬ge minimum *</label>
                                <input asp-for="AgeMinimumConducteur" type="number" class="form-control" />
                                <span asp-validation-for="AgeMinimumConducteur" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="AnciennetePermisMinimum" class="form-label">AnciennetÈ permis (annÈes) *</label>
                                <input asp-for="AnciennetePermisMinimum" type="number" class="form-control" />
                                <span asp-validation-for="AnciennetePermisMinimum" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input asp-for="AssuranceIncluse" type="checkbox" class="form-check-input" />
                                    <label asp-for="AssuranceIncluse" class="form-check-label">Assurance incluse</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input asp-for="LivraisonPossible" type="checkbox" class="form-check-input" />
                                    <label asp-for="LivraisonPossible" class="form-check-label">Livraison possible</label>
                                </div>
                            </div>
                        </div>

                        <h5 class="mb-3"><i class="fas fa-calendar-alt"></i> PÈriode de disponibilitÈ</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DateDebut" class="form-label">Date de dÈbut *</label>
                                <input asp-for="DateDebut" type="date" class="form-control" />
                                <span asp-validation-for="DateDebut" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DateFin" class="form-label">Date de fin *</label>
                                <input asp-for="DateFin" type="date" class="form-control" />
                                <span asp-validation-for="DateFin" class="text-danger"></span>
                            </div>
                        </div>

                        <h5 class="mb-3"><i class="fas fa-toggle-on"></i> Statut</h5>
                        <div class="form-check mb-3">
                            <input asp-for="EstActive" type="checkbox" class="form-check-input" />
                            <label asp-for="EstActive" class="form-check-label">
                                Offre active
                                <small class="text-muted d-block">
                                    Si cochÈe, l'offre sera visible publiquement. Sinon, elle sera masquÈe.
                                </small>
                            </label>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-controller="Agence" asp-action="Dashboard" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save"></i> Mettre ‡ jour
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.querySelector('form').addEventListener('submit', function(e) {
            const dateDebut = document.querySelector('input[name="DateDebut"]').value;
            const dateFin = document.querySelector('input[name="DateFin"]').value;
            
            if (dateDebut && dateFin && new Date(dateFin) <= new Date(dateDebut)) {
                e.preventDefault();
                alert('La date de fin doit Ítre postÈrieure ‡ la date de dÈbut.');
                return false;
            }
        });

        const prixJour = document.querySelector('input[name="PrixParJour"]');
        const prixSemaine = document.querySelector('input[name="PrixParSemaine"]');
        
        if (prixJour && prixSemaine) {
            prixJour.addEventListener('blur', function() {
                if (this.value && (!prixSemaine.value || prixSemaine.value == 0)) {
                    prixSemaine.value = (this.value * 7 * 0.85).toFixed(2);
                }
            });
        }

        const livraisonCheckbox = document.querySelector('input[name="LivraisonPossible"]');
        const fraisLivraison = document.querySelector('input[name="FraisLivraison"]');
        
        if (livraisonCheckbox && fraisLivraison) {
            function toggleFraisLivraison() {
                fraisLivraison.closest('.mb-3').style.display = 
                    livraisonCheckbox.checked ? 'block' : 'none';
            }
            
            livraisonCheckbox.addEventListener('change', toggleFraisLivraison);
            toggleFraisLivraison();
        }
    </script>
}