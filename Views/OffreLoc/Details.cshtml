@model AgenceLocationVoiture.Models.OffreLoc
@{
    ViewData["Title"] = Model.Titre;

    var currentClient = ViewBag.CurrentClient as AgenceLocationVoiture.Models.Client;

    var allPhotos = new List<string>();
    if (!string.IsNullOrEmpty(Model.Voiture?.PhotoPrincipaleUrl))
    {
        allPhotos.Add(Model.Voiture.PhotoPrincipaleUrl);
    }
    if (Model.Voiture?.PhotosUrls != null && Model.Voiture.PhotosUrls.Any())
    {
        allPhotos.AddRange(Model.Voiture.PhotosUrls);
    }
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-8">
            @if (allPhotos.Any())
            {
                <div id="carouselOffre" class="carousel slide mb-4" data-bs-ride="carousel">
                    @if (allPhotos.Count > 1)
                    {
                        <div class="carousel-indicators">
                            @for (int i = 0; i < allPhotos.Count; i++)
                            {
                                <button type="button" data-bs-target="#carouselOffre" data-bs-slide-to="@i" 
                                        class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")" 
                                        aria-label="Slide @(i + 1)"></button>
                            }
                        </div>
                    }

                    <div class="carousel-inner rounded">
                        @for (int i = 0; i < allPhotos.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@allPhotos[i]" class="d-block w-100" 
                                     alt="@Model.Titre - Photo @(i + 1)" 
                                     style="height: 450px; object-fit: cover;" />
                            </div>
                        }
                    </div>

                    @if (allPhotos.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselOffre" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Précédent</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselOffre" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Suivant</span>
                        </button>
                    }

                    @if (allPhotos.Count > 1)
                    {
                        <div class="position-absolute bottom-0 end-0 m-3 badge bg-dark bg-opacity-75">
                            <i class="fas fa-images"></i> @allPhotos.Count photo(s)
                        </div>
                    }
                </div>

                @if (allPhotos.Count > 1)
                {
                    <div class="row g-2 mb-4">
                        @for (int i = 0; i < Math.Min(allPhotos.Count, 6); i++)
                        {
                            <div class="col-2">
                                <img src="@allPhotos[i]" 
                                     class="img-thumbnail cursor-pointer" 
                                     alt="Miniature @(i + 1)"
                                     data-bs-target="#carouselOffre" 
                                     data-bs-slide-to="@i"
                                     style="cursor: pointer; height: 70px; object-fit: cover; width: 100%;"/>
                            </div>
                        }
                        @if (allPhotos.Count > 6)
                        {
                            <div class="col-2 d-flex align-items-center justify-content-center">
                                <span class="badge bg-secondary fs-6">+@(allPhotos.Count - 6)</span>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="bg-light rounded mb-4 d-flex align-items-center justify-content-center" style="height: 450px;">
                    <div class="text-center">
                        <i class="fas fa-car fa-5x text-muted mb-3"></i>
                        <p class="text-muted">Aucune photo disponible</p>
                    </div>
                </div>
            }

            <div class="card mb-4">
                <div class="card-body">
                    <h2>@Model.Titre</h2>
                    <p class="lead">@Model.Description</p>

                    <hr />

                    <h5><i class="fas fa-car"></i> Véhicule</h5>
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <strong>@Model.Voiture?.Marque @Model.Voiture?.Modele</strong><br />
                            <small class="text-muted">
                                <i class="fas fa-calendar"></i> @Model.Voiture?.Annee<br />
                                <i class="fas fa-palette"></i> @Model.Voiture?.Couleur
                            </small>
                        </div>
                        <div class="col-md-6">
                            <span class="badge bg-primary">@Model.Voiture?.Categorie</span>
                            <span class="badge bg-secondary">@Model.Voiture?.TypeCarburant</span>
                            <span class="badge bg-info">@Model.Voiture?.Transmission</span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <a asp-controller="Voiture" asp-action="Details" asp-route-id="@Model.VoitureId" 
                           class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-info-circle"></i> Voir toutes les caractéristiques du véhicule
                        </a>
                    </div>

                    <h5><i class="fas fa-info-circle"></i> Conditions</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <i class="fas fa-road text-primary"></i> <strong>Kilométrage inclus :</strong> @Model.KilometrageInclus km/jour
                            @if (Model.FraisKmSupplementaire.HasValue)
                            {
                                <br /><small class="text-muted">Km sup: @Model.FraisKmSupplementaire.Value TND/km</small>
                            }
                        </div>
                        <div class="col-md-6 mb-3">
                            <i class="fas fa-user text-primary"></i> <strong>Âge minimum :</strong> @Model.AgeMinimumConducteur ans
                        </div>
                        <div class="col-md-6 mb-3">
                            <i class="fas fa-id-card text-primary"></i> <strong>Permis depuis :</strong> @Model.AnciennetePermisMinimum an(s)
                        </div>
                        <div class="col-md-6 mb-3">
                            <i class="fas fa-shield-alt text-primary"></i> <strong>Assurance :</strong> 
                            @if (Model.AssuranceIncluse)
                            {
                                <span class="badge bg-success">Incluse</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Non incluse</span>
                            }
                        </div>
                        @if (Model.CautionMontant.HasValue)
                        {
                            <div class="col-md-6 mb-3">
                                <i class="fas fa-coins text-primary"></i> <strong>Caution :</strong> @Model.CautionMontant.Value TND
                            </div>
                        }
                        @if (Model.LivraisonPossible)
                        {
                            <div class="col-md-6 mb-3">
                                <i class="fas fa-truck text-primary"></i> <strong>Livraison :</strong> 
                                Possible (@(Model.FraisLivraison?.ToString()+" TND" ?? "Gratuit"))
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h5><i class="fas fa-building"></i> Agence</h5>
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h6>@Model.Agence?.NomAgence</h6>
                            <p class="mb-0">
                                <i class="fas fa-map-marker-alt"></i> @Model.Agence?.Adresse, @Model.Agence?.CodePostal @Model.Agence?.Ville<br />
                                <i class="fas fa-phone"></i> @Model.Agence?.PhoneNumber
                            </p>
                        </div>
                        <div class="col-md-4 text-end">
                            <a asp-controller="Agence" asp-action="Details" asp-route-id="@Model.AgenceId" class="btn btn-outline-primary">
                                Voir l'agence
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow sticky-top" style="top: 20px;">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <div class="h2 text-primary mb-0">@Model.PrixParJour TND</div>
                        <small class="text-muted">par jour</small>
                    </div>

                   
                    <hr />

                    <div class="mb-3">
                        <small class="text-muted">
                            <i class="fas fa-calendar-alt"></i> Disponible du<br />
                            <strong>@Model.DateDebut.ToString("dd/MM/yyyy")</strong> au <strong>@Model.DateFin.ToString("dd/MM/yyyy")</strong>
                        </small>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true && currentClient!=null && currentClient.PermisVerifie)
                    {
                        <a asp-controller="DemandeLoc" asp-action="Create" asp-route-offreId="@Model.Id" class="btn btn-primary w-100 btn-lg">
                            <i class="fas fa-paper-plane"></i> Faire une demande
                        </a>
                    }
                    else if (User.Identity?.IsAuthenticated == true && currentClient == null)
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-info-circle"></i> Seuls les clients peuvent faire une demande.
                        </div>
                    }
                    else if (User.Identity?.IsAuthenticated == true && currentClient != null)
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-info-circle"></i> Seuls les clients avec Permis verifiée peuvent faire une demande.
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Url.Action("Details", "OffreLoc", new { id = Model.Id })" class="btn btn-primary w-100 btn-lg">
                            <i class="fas fa-sign-in-alt"></i> Connexion pour réserver
                        </a>
                        <div class="text-center mt-2">
                            <small>
                                Pas encore inscrit ? 
                                <a asp-controller="Account" asp-action="RegisterClient">S'inscrire</a>
                            </small>
                        </div>
                    }

                    <hr />

                    <div class="text-center">
                        <small class="text-muted">
                            <i class="fas fa-check-circle text-success"></i> Annulation gratuite<br />
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>