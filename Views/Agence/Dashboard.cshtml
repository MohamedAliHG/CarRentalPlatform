@model AgenceLocationVoiture.Models.Agence
@{
    ViewData["Title"] = "Tableau de bord";
    var voitures = ViewBag.Voitures as IEnumerable<AgenceLocationVoiture.Models.Voiture>;
    var offres = ViewBag.Offres as IEnumerable<AgenceLocationVoiture.Models.OffreLoc>;
    var avis = ViewBag.Avis as IEnumerable<AgenceLocationVoiture.Models.Avis>;
    var noteMoyenne = ViewBag.NoteMoyenne;
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1><i class="fas fa-tachometer-alt"></i> Tableau de bord</h1>
            <p class="lead">Bienvenue, @Model.NomAgence</p>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card dashboard-card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Vťhicules</h6>
                            <h2 class="mb-0">@(voitures?.Count() ?? 0)</h2>
                        </div>
                        <i class="fas fa-car fa-2x text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card dashboard-card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Offres actives</h6>
                            <h2 class="mb-0">@(offres?.Count(o => o.EstActive) ?? 0)</h2>
                        </div>
                        <i class="fas fa-tag fa-2x text-success"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card dashboard-card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Note moyenne</h6>
                            <h2 class="mb-0">@noteMoyenne.ToString("0.0")/5</h2>
                        </div>
                        <i class="fas fa-star fa-2x text-warning"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card dashboard-card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Avis</h6>
                            <h2 class="mb-0">@(avis?.Count() ?? 0)</h2>
                        </div>
                        <i class="fas fa-comment fa-2x text-info"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-bolt"></i> Actions rapides</h5>
                </div>
                <div class="card-body">
                    <div class="row justify-content-center">
                        <div class="col-md-2 mb-3">
                            <a asp-controller="Voiture" asp-action="Create" class="btn btn-outline-primary w-100 py-3">
                                <i class="fas fa-car fa-2x d-block mb-2"></i>Ajouter un vťhicule
                            </a>
                        </div>
                        <div class="col-md-2 mb-3">
                            <a asp-controller="OffreLoc" asp-action="Create" class="btn btn-outline-success w-100 py-3">
                                <i class="fas fa-tag fa-2x d-block mb-2"></i>Crťer une offre
                            </a>
                        </div>
                        <div class="col-md-2 mb-3">
                            <a asp-controller="DemandeLoc" asp-action="Index" class="btn btn-outline-info w-100 py-3">
                                <i class="fas fa-envelope fa-2x d-block mb-2"></i>Voir les demandes
                            </a>
                        </div>
                        <div class="col-md-2 mb-3">
                            <a asp-controller="Agence" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100 py-3">
                                <i class="fas fa-eye fa-2x d-block mb-2"></i>Voir mon profil
                            </a>
                        </div>
                        <div class="col-md-2 mb-3">
                            <a asp-action="Edit" class="btn btn-outline-secondary w-100 py-3">
                                <i class="fas fa-edit fa-2x d-block mb-2"></i> Modifier mes informations
                        </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-white">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-car"></i> Mes vťhicules</h5>
                <a asp-controller="Voiture" asp-action="Create" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus"></i> Ajouter
                </a>
            </div>
        </div>
        <div class="card-body">
            @if (voitures != null && voitures.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Vťhicule</th>
                                <th>Annťe</th>
                                <th>Immatriculation</th>
                                <th>Catťgorie</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var voiture in voitures)
                            {
                                <tr>
                                    <td>@voiture.Marque @voiture.Modele</td>
                                    <td>@voiture.Annee</td>
                                    <td>@voiture.Immatriculation</td>
                                    <td><span class="badge bg-secondary">@voiture.Categorie</span></td>
                                    <td>
                                        @if (voiture.EstDisponible)
                                        {
                                            <span class="badge bg-success">Disponible</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Indisponible</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="Voiture" asp-action="Details" asp-route-id="@voiture.Id" class="btn btn-sm btn-info" title="Voir">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-controller="Voiture" asp-action="Edit" asp-route-id="@voiture.Id" class="btn btn-sm btn-warning" title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-controller="Voiture" asp-action="ToggleActive" asp-route-id="@voiture.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-secondary" title="@(voiture.EstDisponible ? "Dťsactiver" : "Activer")">
                                                <i class="fas fa-power-off"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    <i class="fas fa-info-circle"></i> Vous n'avez pas encore ajoutť de vťhicules.
                    <a asp-controller="Voiture" asp-action="Create" class="alert-link">Ajouter votre premier vťhicule</a>
                </div>
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-white">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-tag"></i> Mes offres de location</h5>
                <a asp-controller="OffreLoc" asp-action="Create" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus"></i> Crťer une offre
                </a>
            </div>
        </div>
        <div class="card-body">
            @if (offres != null && offres.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Titre</th>
                                <th>Vťhicule</th>
                                <th>Prix/jour</th>
                                <th>Pťriode</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var offre in offres)
                            {
                                <tr>
                                    <td>@offre.Titre</td>
                                    <td>@offre.Voiture?.Marque @offre.Voiture?.Modele</td>
                                    <td>@offre.PrixParJour TND</td>
                                    <td>@offre.DateDebut.ToString("dd/MM/yy") - @offre.DateFin.ToString("dd/MM/yy")</td>
                                    <td>
                                        @if (offre.EstActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="OffreLoc" asp-action="Details" asp-route-id="@offre.Id" class="btn btn-sm btn-info" title="Voir">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-controller="OffreLoc" asp-action="Edit" asp-route-id="@offre.Id" class="btn btn-sm btn-warning" title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-controller="OffreLoc" asp-action="ToggleActive" asp-route-id="@offre.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-secondary" title="@(offre.EstActive ? "Dťsactiver" : "Activer")">
                                                <i class="fas fa-power-off"></i>
                                            </button>
                                        </form>
                                       
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    <i class="fas fa-info-circle"></i> Vous n'avez pas encore crťť d'offres.
                    <a asp-controller="OffreLoc" asp-action="Create" class="alert-link">Crťer votre premiŤre offre</a>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="fas fa-star"></i> Avis rťcents</h5>
        </div>
        <div class="card-body">
            @if (avis != null && avis.Any())
            {
                @foreach (var av in avis.OrderByDescending(a => a.DateAvis).Take(5))
                {
                    <div class="border-bottom pb-3 mb-3">
                        <div class="d-flex justify-content-between">
                            <div>
                                <strong>@av.Client?.Prenom @av.Client?.Nom</strong>
                                <span class="stars ms-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= av.Note)
                                        {
                                            <i class="fas fa-star text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="far fa-star text-warning"></i>
                                        }
                                    }
                                </span>
                            </div>
                            <small class="text-muted">@av.DateAvis.ToString("dd/MM/yyyy")</small>
                        </div>
                        <p class="mb-2 mt-2">@av.Commentaire</p>
                        @if (string.IsNullOrEmpty(av.ReponseAgence))
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#reponseModal@(av.Id)">
                                <i class="fas fa-reply"></i> Rťpondre
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-light mt-2 mb-0">
                                <strong><i class="fas fa-reply"></i> Votre rťponse :</strong> @av.ReponseAgence
                                <br /><small class="text-muted">Rťpondu le @av.DateReponse?.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info mb-0">
                    <i class="fas fa-info-circle"></i> Aucun avis pour le moment.
                </div>
            }
        </div>
    </div>
</div>

@if (avis != null && avis.Any())
{
    @foreach (var av in avis.OrderByDescending(a => a.DateAvis).Take(5))
    {
        @if (string.IsNullOrEmpty(av.ReponseAgence))
        {
            <div class="modal fade" id="reponseModal@(av.Id)" tabindex="-1" aria-labelledby="reponseModalLabel@(av.Id)" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-controller="Avis" asp-action="Respond" asp-route-id="@av.Id" method="post">
                            @Html.AntiForgeryToken()
                            <div class="modal-header bg-primary text-white">
                                <h5 class="modal-title" id="reponseModalLabel@(av.Id)">Rťpondre ŗ l'avis</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label"><strong>Avis de @av.Client?.Prenom @av.Client?.Nom</strong></label>
                                    <div class="p-3 bg-light rounded">
                                        <span class="stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= av.Note)
                                                {
                                                    <i class="fas fa-star text-warning"></i>
                                                }
                                                else
                                                {
                                                    <i class="far fa-star text-warning"></i>
                                                }
                                            }
                                        </span>
                                        <p class="mt-2 mb-0">@av.Commentaire</p>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Votre rťponse *</label>
                                    <textarea name="reponseAgence" class="form-control" rows="4" placeholder="Rťdigez votre rťponse au client..." required></textarea>
                                    <small class="form-text text-muted">Soyez professionnel et courtois dans votre rťponse</small>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                    <i class="fas fa-times"></i> Annuler
                                </button>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-paper-plane"></i> Envoyer la rťponse
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('[id^="reponseModal"]').forEach(function(modal) {
                modal.addEventListener('hidden.bs.modal', function () {
                    var form = this.querySelector('form');
                    if (form) {
                        form.reset();
                    }
                });
            });
        });
    </script>
}