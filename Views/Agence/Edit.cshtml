@model AgenceLocationVoiture.ViewModels.AgenceEditViewModel
@{
    ViewData["Title"] = "Modifier mes informations";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0"><i class="fas fa-edit"></i> Modifier les informations de l'agence</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <h5 class="mb-3"><i class="fas fa-building"></i> Informations générales</h5>
                        
                        <div class="mb-3">
                            <label asp-for="NomAgence" class="form-label"></label>
                            <input asp-for="NomAgence" class="form-control" />
                            <span asp-validation-for="NomAgence" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="4" 
                                      placeholder="Présentez votre agence..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <h5 class="mb-3 mt-4"><i class="fas fa-image"></i> Logo de l'agence</h5>
                        
                        @if (!string.IsNullOrEmpty(Model.LogoUrl))
                        {
                            <div class="mb-3">
                                <label class="form-label">Logo actuel</label>
                                <div>
                                    <img src="@Model.LogoUrl" alt="Logo actuel" class="img-thumbnail" style="max-width: 200px;" />
                                </div>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="LogoFile" class="form-label"></label>
                            <input asp-for="LogoFile" type="file" class="form-control" accept="image/*" id="logoFile" />
                            <small class="form-text text-muted">
                                Formats acceptés: JPG, PNG, GIF (Max: 5MB)
                            </small>
                            <div id="logoPreview" class="mt-2"></div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ou saisir une URL</label>
                            <input asp-for="LogoUrl" class="form-control" placeholder="https://..." />
                        </div>

                        <h5 class="mb-3 mt-4"><i class="fas fa-map-marker-alt"></i> Coordonnées</h5>
                        
                        <div class="mb-3">
                            <label asp-for="Adresse" class="form-label"></label>
                            <input asp-for="Adresse" class="form-control" />
                            <span asp-validation-for="Adresse" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Ville" class="form-label"></label>
                                <input asp-for="Ville" class="form-control" />
                                <span asp-validation-for="Ville" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="CodePostal" class="form-label"></label>
                                <input asp-for="CodePostal" class="form-control" maxlength="5" />
                                <span asp-validation-for="CodePostal" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Telephone" class="form-label"></label>
                            <input asp-for="Telephone" type="tel" class="form-control" />
                            <span asp-validation-for="Telephone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SiteWeb" class="form-label"></label>
                            <input asp-for="SiteWeb" class="form-control" placeholder="https://www.example.com" />
                            <span asp-validation-for="SiteWeb" class="text-danger"></span>
                        </div>

                     
                       

                        <div class="alert alert-info mt-3">
                            <i class="fas fa-info-circle"></i> 
                            <strong>Note :</strong> Le numéro SIRET et l'email ne peuvent pas ętre modifiés. 
                            Contactez l'administrateur si nécessaire.
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Dashboard" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save"></i> Enregistrer les modifications
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.getElementById('logoFile')?.addEventListener('change', function(e) {
            const preview = document.getElementById('logoPreview');
            preview.innerHTML = '';
            
            const file = e.target.files[0];
            if (file) {
                if (file.size > 5 * 1024 * 1024) {
                    alert('La taille du fichier ne doit pas dépasser 5MB');
                    this.value = '';
                    return;
                }

                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.innerHTML = `
                        <div class="text-center p-2">
                            <p class="text-success mb-2"><i class="fas fa-check-circle"></i> Nouveau logo sélectionné</p>
                            <img src="${e.target.result}" class="img-thumbnail" style="max-width: 200px;" />
                        </div>
                    `;
                };
                reader.readAsDataURL(file);
            }
        });

        const form = document.querySelector('form');
        form?.addEventListener('submit', function(e) {
            const ouverture = document.querySelector('input[name="HeureOuverture"]')?.value;
            const fermeture = document.querySelector('input[name="HeureFermeture"]')?.value;
            
            if (ouverture && fermeture && fermeture <= ouverture) {
                e.preventDefault();
                alert('L\'heure de fermeture doit ętre aprčs l\'heure d\'ouverture');
                return false;
            }
        });
    </script>
}