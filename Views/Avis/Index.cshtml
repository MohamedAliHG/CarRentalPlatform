@model IEnumerable<AgenceLocationVoiture.Models.Avis>
@{
    ViewData["Title"] = "Avis clients";
    var agence = ViewBag.Agence as AgenceLocationVoiture.Models.Agence;
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-md-12">
            @if (agence != null)
            {
                <h1><i class="fas fa-star"></i> Avis pour @agence.NomAgence</h1>
                <p class="lead">Découvrez les retours d'expérience de nos clients</p>
            }
            else
            {
                <h1><i class="fas fa-star"></i> Derniers avis</h1>
                <p class="lead">Les avis de nos clients</p>
            }
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var avis in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h6 class="mb-1">@avis.Client?.Prenom @avis.Client?.Nom</h6>
                                    <small class="text-muted">@avis.DateAvis.ToString("dd MMMM yyyy")</small>
                                </div>
                                <div class="stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= avis.Note)
                                        {
                                            <i class="fas fa-star"></i>
                                        }
                                        else
                                        {
                                            <i class="far fa-star"></i>
                                        }
                                    }
                                </div>
                            </div>

                            <p class="card-text">@avis.Commentaire</p>

                            @if (avis.NoteQualiteVehicule.HasValue || avis.NoteServiceClient.HasValue || 
                                 avis.NoteRapportQualitePrix.HasValue || avis.NoteProprete.HasValue)
                            {
                                <div class="border-top pt-3 mt-3">
                                    <small class="text-muted">
                                        @if (avis.NoteQualiteVehicule.HasValue)
                                        {
                                            <span class="me-3">
                                                <i class="fas fa-car"></i> @avis.NoteQualiteVehicule/5
                                            </span>
                                        }
                                        @if (avis.NoteServiceClient.HasValue)
                                        {
                                            <span class="me-3">
                                                <i class="fas fa-headset"></i> @avis.NoteServiceClient/5
                                            </span>
                                        }
                                        @if (avis.NoteProprete.HasValue)
                                        {
                                            <span class="me-3">
                                                <i class="fas fa-broom"></i> @avis.NoteProprete/5
                                            </span>
                                        }
                                    </small>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(avis.ReponseAgence))
                            {
                                <div class="alert alert-light mt-3 mb-0">
                                    <strong><i class="fas fa-reply"></i> Réponse de l'agence :</strong><br />
                                    @avis.ReponseAgence
                                    <br /><small class="text-muted">@avis.DateReponse?.ToString("dd/MM/yyyy")</small>
                                </div>
                            }

                            @if (agence == null)
                            {
                                <div class="border-top pt-3 mt-3">
                                    <small>
                                        <i class="fas fa-building"></i> @avis.Agence?.NomAgence
                                    </small>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-info-circle fa-3x mb-3"></i>
            <h4>Aucun avis pour le moment</h4>
            <p>Soyez le premier ŕ partager votre expérience !</p>
        </div>
    }
</div>