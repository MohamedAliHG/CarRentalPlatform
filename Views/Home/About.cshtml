@{
    ViewData["Title"] = "À propos";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="text-center mb-5"><i class="fas fa-info-circle"></i> À propos de KARHABTI</h1>

            <div class="card mb-4">
                <div class="card-body">
                    <h3>Notre mission</h3>
                    <p class="lead">
                        KARHABTI est la plateforme de référence qui connecte les agences de location de voitures 
                        avec les clients à la recherche du véhicule idéal pour leurs déplacements.
                    </p>
                    <p>
                        Notre objectif est de simplifier le processus de location en offrant une plateforme transparente, 
                        sécurisée et facile à utiliser, tout en garantissant les meilleurs prix du marché.
                    </p>
                </div>
            </div>

            <div class="row mb-4 justify-content-center">
                <div class="col-md-4 text-center mb-2">
                    <div class="card h-100">
                        <div class="card-body">
                            <i class="fas fa-building fa-3x text-primary mb-3"></i>
                            <h5>Agences partenaires</h5>
                            <p class="mb-0">Des centaines d'agences vérifiées à votre service</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 text-center mb-2">
                    <div class="card h-100">
                        <div class="card-body">
                            <i class="fas fa-car fa-3x text-primary mb-3"></i>
                            <h5>Large choix</h5>
                            <p class="mb-0">Des milliers de véhicules disponibles dans toute la Tunisie</p>
                        </div>
                    </div>
                </div>
                
            </div>

            <div class="card">
                <div class="card-body">
                    <h3>Nos valeurs</h3>
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="fas fa-check text-success"></i> <strong>Transparence</strong> : Prix clairs, sans frais cachés</li>
                        <li class="mb-2"><i class="fas fa-check text-success"></i> <strong>Qualité</strong> : Sélection rigoureuse de nos partenaires</li>
                        <li class="mb-2"><i class="fas fa-check text-success"></i> <strong>Service</strong> : Support client disponible 7j/7</li>
                        <li class="mb-2"><i class="fas fa-check text-success"></i> <strong>Innovation</strong> : Amélioration continue de nos services</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>