@model IEnumerable<AgenceLocationVoiture.Models.DemandeLoc>
@{
    ViewData["Title"] = "Demandes de location";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-envelope"></i> Toutes les demandes de location</h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour au tableau de bord
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Client</th>
                                <th>Agence</th>
                                <th>Offre</th>
                                <th>Période</th>
                                <th>Date demande</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var demande in Model.OrderByDescending(d => d.DateDemande))
                            {
                                <tr>
                                    <td>@demande.Id</td>
                                    <td>@demande.Client?.Nom @demande.Client?.Prenom</td>
                                    <td>@demande.OffreLoc?.Agence?.NomAgence</td>
                                    <td>@demande.OffreLoc?.Titre</td>
                                    <td>
                                        @demande.DateDebut.ToString("dd/MM") - @demande.DateFin.ToString("dd/MM")
                                    </td>
                                    <td>@demande.DateDemande.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="@AgenceLocationVoiture.Helpers.EnumHelpers.GetStatutDemandeBadgeClass(demande.Statut)">
                                            @AgenceLocationVoiture.Helpers.EnumHelpers.GetStatutDemandeLabel(demande.Statut)
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-controller="DemandeLoc" asp-action="Details" asp-route-id="@demande.Id" 
                                           class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> Aucune demande enregistrée.
                </div>
            }
        </div>
    </div>
</div>