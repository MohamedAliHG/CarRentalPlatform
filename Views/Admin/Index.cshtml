@{
    ViewData["Title"] = "Administration";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1><i class="fas fa-shield-alt"></i> Panneau d'administration</h1>
            <p class="lead">Vue d'ensemble de la plateforme</p>
        </div>
    </div>

    <div class="row mb-4 justify-content-center">
        <div class="col-md-2">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <i class="fas fa-building fa-3x text-primary mb-2"></i>
                    <h3 class="mb-0">@ViewBag.NombreAgences</h3>
                    <p class="text-muted mb-0">Agences</p>
                </div>
                <div class="card-footer bg-transparent">
                    <a asp-action="Agences" class="btn btn-sm btn-outline-primary w-100">Gérer</a>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <i class="fas fa-users fa-3x text-success mb-2"></i>
                    <h3 class="mb-0">@ViewBag.NombreClients</h3>
                    <p class="text-muted mb-0">Clients</p>
                </div>
                <div class="card-footer bg-transparent">
                    <a asp-action="Clients" class="btn btn-sm btn-outline-success w-100">Gérer</a>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <i class="fas fa-car fa-3x text-info mb-2"></i>
                    <h3 class="mb-0">@ViewBag.NombreVoitures</h3>
                    <p class="text-muted mb-0">Véhicules</p>
                </div>
                <div class="card-footer bg-transparent">
                    <a asp-action="Voitures" class="btn btn-sm btn-outline-info w-100">Voir</a>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <i class="fas fa-tag fa-3x text-warning mb-2"></i>
                    <h3 class="mb-0">@ViewBag.NombreOffres</h3>
                    <p class="text-muted mb-0">Offres</p>
                </div>
                <div class="card-footer bg-transparent">
                    <a asp-action="Offres" class="btn btn-sm btn-outline-warning w-100">Voir</a>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <i class="fas fa-envelope fa-3x text-danger mb-2"></i>
                    <h3 class="mb-0">@ViewBag.NombreDemandes</h3>
                    <p class="text-muted mb-0">Demandes</p>
                </div>
                <div class="card-footer bg-transparent">
                    <a asp-action="Demandes" class="btn btn-sm btn-outline-danger w-100">Voir</a>
                </div>
            </div>
        </div>

    </div>

    <div class="row">

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h5 class="mb-0"><i class="fas fa-clock"></i> Demandes en attente</h5>
                </div>
                <div class="card-body">
                    @{
                        var demandesEnAttente = ViewBag.DemandesEnAttente as IEnumerable<AgenceLocationVoiture.Models.DemandeLoc>;
                    }
                    @if (demandesEnAttente != null && demandesEnAttente.Any())
                    {
                        <div class="list-group">
                            @foreach (var demande in demandesEnAttente.Take(5))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>Demande #@demande.Id</strong><br />
                                            <small class="text-muted">
                                                Client: @demande.Client?.Nom<br />
                                                Agence: @demande.OffreLoc?.Agence?.NomAgence
                                            </small>
                                        </div>
                                        <a asp-controller="DemandeLoc" asp-action="Details" asp-route-id="@demande.Id" 
                                           class="btn btn-sm btn-primary">Voir</a>
                                    </div>
                                </div>
                            }
                        </div>
                        @if (demandesEnAttente.Count() > 5)
                        {
                            <div class="text-center mt-3">
                                <a asp-action="Demandes" class="btn btn-outline-primary">
                                    Voir toutes les demandes (@demandesEnAttente.Count())
                                </a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="fas fa-check-circle"></i> Aucune demande en attente
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="fas fa-exclamation-triangle"></i> Agences en attente de vérification
                    </h5>
                </div>
                <div class="card-body">
                    @{
                        var agencesNonVerifiees = ViewBag.AgencesNonVerifiees as IEnumerable<AgenceLocationVoiture.Models.Agence>;
                    }
                    @if (agencesNonVerifiees != null && agencesNonVerifiees.Any())
                    {
                        <div class="list-group">
                            @foreach (var agence in agencesNonVerifiees.Take(5))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>@agence.NomAgence</strong><br />
                                            <small class="text-muted">
                                                <i class="fas fa-map-marker-alt"></i> @agence.Ville<br />
                                                <i class="fas fa-calendar"></i> Inscrite le @agence.DateInscription.ToString("dd/MM/yyyy")
                                            </small>
                                        </div>
                                        <div>
                                            <a asp-action="Agences" class="btn btn-sm btn-primary">Voir</a>
                                            <form asp-action="VerifyAgence" asp-route-id="@agence.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success"
                                                        onclick="return confirm('Vérifier l\'agence @agence.NomAgence ?');">
                                                    <i class="fas fa-check"></i> Vérifier
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        @if (agencesNonVerifiees.Count() > 5)
                        {
                            <div class="text-center mt-3">
                                <a asp-action="Agences" class="btn btn-outline-warning">
                                    Voir toutes les agences (@agencesNonVerifiees.Count())
                                </a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-success mb-0">
                            <i class="fas fa-check-circle"></i> Toutes les agences sont vérifiées
                        </div>
                    }
                </div>
            </div>
        </div>
        
    </div>


    <div class="row mt-4">
        <div class="col-md-12 text-center">
            <a asp-action="Statistics" class="btn btn-lg btn-primary">
                <i class="fas fa-chart-bar"></i> Voir les statistiques détaillées
            </a>
        </div>
    </div>

</div>