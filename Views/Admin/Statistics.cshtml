@{
    ViewData["Title"] = "Statistiques";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-chart-bar"></i> Statistiques détaillées</h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour au tableau de bord
        </a>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card text-center">
                <div class="card-header bg-primary text-white">
                    <h5><i class="fas fa-building"></i> Agences</h5>
                </div>
                <div class="card-body">
                    <h2>@ViewBag.AgencesVerifiees</h2>
                    <p class="text-muted">Agences vérifiées</p>

                    <h2>@ViewBag.AgencesNonVerifiees</h2>
                    <p class="text-muted">Agences non vérifiées</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card text-center">
                <div class="card-header bg-success text-white">
                    <h5><i class="fas fa-users"></i> Clients</h5>
                </div>
                <div class="card-body">
                    <h2>@ViewBag.ClientsVerifies</h2>
                    <p class="text-muted">Permis vérifiés</p>

                    <h2>@ViewBag.ClientsNonVerifies</h2>
                    <p class="text-muted">Permis non vérifiés</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card text-center">
                <div class="card-header bg-info text-white">
                    <h5><i class="fas fa-car"></i> Véhicules</h5>
                </div>
                <div class="card-body">
                    <h2>@ViewBag.VoituresDisponibles</h2>
                    <p class="text-muted">Véhicules disponibles</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card text-center">
                <div class="card-header bg-warning text-white">
                    <h5><i class="fas fa-tag"></i> Offres</h5>
                </div>
                <div class="card-body">
                    <h2>@ViewBag.OffresActives</h2>
                    <p class="text-muted">Offres actives</p>

                    <h2>@ViewBag.OffresInActives</h2>
                    <p class="text-muted">Offres inactives</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card text-center">
                <div class="card-header bg-danger text-white">
                    <h5><i class="fas fa-clock"></i> Demandes de Location</h5>
                </div>
                <div class="card-body">
                    <h2>@ViewBag.DemandesEnAttente</h2>
                    <p class="text-muted">En attente</p>

                    <h2>@ViewBag.DemandesAcceptees</h2>
                    <p class="text-muted">Acceptées</p>

                </div>
            </div>
        </div>
        
    </div>
</div>