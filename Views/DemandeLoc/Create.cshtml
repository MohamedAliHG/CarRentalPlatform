@model AgenceLocationVoiture.ViewModels.CreateDemandeLocViewModel
@{
    ViewData["Title"] = "Faire une demande de location";
    var offre = ViewBag.Offre as AgenceLocationVoiture.Models.OffreLoc;
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0"><i class="fas fa-paper-plane"></i> Demande de location</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="OffreLocId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> Vous Ļtes sur le point de faire une demande pour <strong>@offre?.Titre</strong>
                        </div>

                        <h5 class="mb-3"><i class="fas fa-calendar-alt"></i> Dates de location</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DateDebut" class="form-label">Date de dķbut *</label>
                                <input asp-for="DateDebut" type="date" class="form-control" />
                                <span asp-validation-for="DateDebut" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DateFin" class="form-label">Date de fin *</label>
                                <input asp-for="DateFin" type="date" class="form-control" />
                                <span asp-validation-for="DateFin" class="text-danger"></span>
                            </div>
                        </div>

                        <h5 class="mb-3"><i class="fas fa-map-marker-alt"></i> Lieux</h5>
                        <div class="mb-3">
                            <label asp-for="LieuPriseEnCharge" class="form-label">Lieu de prise en charge *</label>
                            <input asp-for="LieuPriseEnCharge" class="form-control" placeholder="Adresse de prise en charge" />
                            <span asp-validation-for="LieuPriseEnCharge" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LieuRetour" class="form-label">Lieu de retour *</label>
                            <input asp-for="LieuRetour" class="form-control" placeholder="Adresse de retour" />
                            <span asp-validation-for="LieuRetour" class="text-danger"></span>
                        </div>

                        @if (offre?.LivraisonPossible == true)
                        {
                            <div class="form-check mb-3">
                                <input asp-for="LivraisonDemandee" type="checkbox" class="form-check-input" id="livraisonCheck" />
                                <label asp-for="LivraisonDemandee" class="form-check-label">
                                    Je souhaite une livraison 
                                    @if (offre.FraisLivraison.HasValue && offre.FraisLivraison > 0)
                                    {
                                        <text>(+ @offre.FraisLivraison.Value.ToString("C"))</text>
                                    }
                                </label>
                            </div>

                            <div class="mb-3" id="adresseLivraisonDiv" style="display:none;">
                                <label asp-for="AdresseLivraison" class="form-label">Adresse de livraison</label>
                                <input asp-for="AdresseLivraison" class="form-control" placeholder="Votre adresse complĶte" />
                                <span asp-validation-for="AdresseLivraison" class="text-danger"></span>
                            </div>
                        }

                        <h5 class="mb-3"><i class="fas fa-comment"></i> Message (optionnel)</h5>
                        <div class="mb-3">
                            <textarea asp-for="MessageClient" class="form-control" rows="4" placeholder="Ajoutez un message pour l'agence..."></textarea>
                            <span asp-validation-for="MessageClient" class="text-danger"></span>
                        </div>

                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> <strong>Important :</strong>
                            <ul class="mb-0 mt-2">
                                <li>┬ge minimum requis : @offre?.AgeMinimumConducteur ans</li>
                                <li>Permis depuis au moins : @offre?.AnciennetePermisMinimum an(s)</li>
                                @if (offre?.CautionMontant.HasValue == true)
                                {
                                    <li>Caution : @offre.CautionMontant.Value TND</li>
                                }
                            </ul>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-controller="OffreLoc" asp-action="Details" asp-route-id="@Model.OffreLocId" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Retour
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-paper-plane"></i> Envoyer la demande
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            @if (offre != null)
            {
                <div class="card shadow sticky-top" style="top: 20px;">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="fas fa-tag"></i> Rķcapitulatif</h5>
                    </div>
                    <div class="card-body">
                        <h6>@offre.Titre</h6>
                        <p class="text-muted">
                            <i class="fas fa-car"></i> @offre.Voiture?.Marque @offre.Voiture?.Modele<br />
                            <i class="fas fa-building"></i> @offre.Agence?.NomAgence
                        </p>

                        <hr />

                        <div class="text-center mb-3">
                            <div class="h3 text-primary">@offre.PrixParJour TND</div>
                            <small class="text-muted">par jour</small>
                        </div>

                        <div class="alert alert-info text-center mb-0">
                            <small>Prix estimķ : sera confirmķ par l'agence</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('livraisonCheck')?.addEventListener('change', function() {
            document.getElementById('adresseLivraisonDiv').style.display = this.checked ? 'block' : 'none';
        });
    </script>
}