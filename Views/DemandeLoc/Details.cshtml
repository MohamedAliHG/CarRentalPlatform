@model AgenceLocationVoiture.Models.DemandeLoc
@{
    ViewData["Title"] = "Détails de la demande";
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-envelope"></i> Demande #@Model.Id
                        <span class="@AgenceLocationVoiture.Helpers.EnumHelpers.GetStatutDemandeBadgeClass(Model.Statut) float-end">
                            @AgenceLocationVoiture.Helpers.EnumHelpers.GetStatutDemandeLabel(Model.Statut)
                        </span>
                    </h4>
                </div>
                <div class="card-body">
                    <h5><i class="fas fa-calendar-alt"></i> Période de location</h5>
                    <p>
                        Du <strong>@Model.DateDebut.ToString("dd/MM/yyyy")</strong> au <strong>@Model.DateFin.ToString("dd/MM/yyyy")</strong><br />
                        <small class="text-muted">Durée: @((Model.DateFin - Model.DateDebut).Days) jours</small>
                    </p>

                    <hr />

                    <h5><i class="fas fa-map-marker-alt"></i> Lieux</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Prise en charge :</strong><br />
                            @Model.LieuPriseEnCharge
                        </div>
                        <div class="col-md-6">
                            <strong>Retour :</strong><br />
                            @Model.LieuRetour
                        </div>
                    </div>

                    @if (Model.LivraisonDemandee && !string.IsNullOrEmpty(Model.AdresseLivraison))
                    {
                        <div class="alert alert-info mt-3">
                            <i class="fas fa-truck"></i> <strong>Livraison demandée</strong><br />
                            @Model.AdresseLivraison
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.MessageClient))
                    {
                        <hr />
                        <h5><i class="fas fa-comment"></i> Message du client</h5>
                        <p class="alert alert-light">@Model.MessageClient</p>
                    }

                    @if (!string.IsNullOrEmpty(Model.ReponseAgence))
                    {
                        <hr />
                        <h5><i class="fas fa-reply"></i> Réponse de l'agence</h5>
                        <div class="alert alert-success">
                            @Model.ReponseAgence
                            <br /><small class="text-muted">Répondu le @Model.DateReponse?.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                    }

                    @if (Model.MontantTotal.HasValue)
                    {
                        <hr />
                        <h5>Montant total</h5>
                        <div class="h3 text-primary">@Model.MontantTotal.Value TND</div>
                    }

                    @if (User.IsInRole("Agence") && Model.Statut == AgenceLocationVoiture.Models.StatutDemande.EnAttente)
                    {
                        <hr />
                        <div class="row">
                            <div class="col-md-12">
                                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#acceptModal">
                                    <i class="fas fa-check"></i> Accepter la demande
                                </button>
                                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#refuseModal">
                                    <i class="fas fa-times"></i> Refuser la demande
                                </button>
                            </div>
                        </div>
                    }

                    @if (User.IsInRole("Client") && Model.Statut == AgenceLocationVoiture.Models.StatutDemande.EnAttente)
                    {
                        <hr />
                        <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Ętes-vous sűr d\'annuler cette demande ?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-ban"></i> Annuler ma demande
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-tag"></i> Offre</h5>
                </div>
                <div class="card-body">
                    <h6>@Model.OffreLoc?.Titre</h6>
                    <p class="mb-2">
                        <i class="fas fa-car"></i> @Model.OffreLoc?.Voiture?.Marque @Model.OffreLoc?.Voiture?.Modele<br />
                        <i class="fas fa-building"></i> @Model.OffreLoc?.Agence?.NomAgence
                    </p>
                    <a asp-controller="OffreLoc" asp-action="Details" asp-route-id="@Model.OffreLocId" class="btn btn-outline-primary btn-sm w-100">
                        Voir l'offre
                    </a>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        @if (User.IsInRole("Agence"))
                        {
                            <i class="fas fa-user"></i><text> Client</text>
                        }
                        else
                        {
                            <i class="fas fa-building"></i><text> Agence</text>
                        }
                    </h5>
                </div>
                <div class="card-body">
                    @if (User.IsInRole("Agence"))
                    {
                        <p>
                            <strong>@Model.Client?.Prenom @Model.Client?.Nom</strong><br />
                            <i class="fas fa-envelope"></i> @Model.Client?.Email<br />
                            <i class="fas fa-phone"></i> @Model.Client?.PhoneNumber
                        </p>
                    }
                    else
                    {
                        <p>
                            <strong>@Model.OffreLoc?.Agence?.NomAgence</strong><br />
                            <i class="fas fa-map-marker-alt"></i> @Model.OffreLoc?.Agence?.Ville<br />
                            <i class="fas fa-phone"></i> @Model.OffreLoc?.Agence?.PhoneNumber
                        </p>
                        <a asp-controller="Agence" asp-action="Details" asp-route-id="@Model.OffreLoc?.AgenceId" class="btn btn-outline-primary btn-sm w-100">
                            Voir l'agence
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour ŕ la liste
        </a>
    </div>
</div>

@if (User.IsInRole("Agence") && Model.Statut == AgenceLocationVoiture.Models.StatutDemande.EnAttente)
{

    <div class="modal fade" id="acceptModal" tabindex="-1" aria-labelledby="acceptModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="Accept" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title" id="acceptModalLabel">Accepter la demande</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Montant total (TND) *</label>
                            <input type="number" name="montantTotal" step="0.01" class="form-control" required min="0" placeholder="150.00" />
                            <small class="form-text text-muted">Indiquez le montant total de la location</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Message pour le client</label>
                            <textarea name="reponseAgence" class="form-control" rows="3" placeholder="Votre message de confirmation..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="fas fa-times"></i> Annuler
                        </button>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-check"></i> Confirmer l'acceptation
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="refuseModal" tabindex="-1" aria-labelledby="refuseModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="Refuse" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title" id="refuseModalLabel">Refuser la demande</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> Cette action est irréversible.
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Raison du refus *</label>
                            <textarea name="reponseAgence" class="form-control" rows="4" placeholder="Expliquez au client pourquoi vous refusez cette demande..." required></textarea>
                            <small class="form-text text-muted">Soyez courtois et explicite dans votre réponse</small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="fas fa-times"></i> Annuler
                        </button>
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-ban"></i> Confirmer le refus
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var acceptModal = document.getElementById('acceptModal');
            var refuseModal = document.getElementById('refuseModal');
            
            if (acceptModal) {
                acceptModal.addEventListener('hidden.bs.modal', function () {
                    this.querySelector('form').reset();
                });
            }
            
            if (refuseModal) {
                refuseModal.addEventListener('hidden.bs.modal', function () {
                    this.querySelector('form').reset();
                });
            }
        });
    </script>
}