@{
    ViewData["Title"] = "Accès refusé";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <i class="fas fa-ban fa-5x text-danger mb-4"></i>
            <h1 class="display-4">Accès refusé</h1>
            <p class="lead">Vous n'avez pas la permission d'accéder à cette page.</p>
            <hr />
            <p>Si vous pensez qu'il s'agit d'une erreur, veuillez contacter l'administrateur.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="fas fa-home"></i> Retour à l'accueil
            </a>
        </div>
    </div>
</div>