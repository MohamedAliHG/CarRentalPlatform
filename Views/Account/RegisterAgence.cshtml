@model AgenceLocationVoiture.ViewModels.AgenceRegistrationViewModel
@{
    ViewData["Title"] = "Inscription Agence";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="fas fa-building fa-3x text-primary mb-3"></i>
                        <h2>Inscription Agence</h2>
                        <p class="text-muted">Rejoignez notre plateforme de location</p>
                    </div>

                    <form asp-action="RegisterAgence" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <h5 class="mb-3"><i class="fas fa-building"></i> Informations de l'agence</h5>
                        <div class="mb-3">
                            <label asp-for="NomAgence" class="form-label">Nom de l'agence *</label>
                            <input asp-for="NomAgence" class="form-control" />
                            <span asp-validation-for="NomAgence" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NumeroSiret" class="form-label">Numéro SIRET *</label>
                            <input asp-for="NumeroSiret" class="form-control" maxlength="14" placeholder="14 chiffres" />
                            <small class="form-text text-muted">Format: 12345678901234</small>
                            <span asp-validation-for="NumeroSiret" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" 
                                      placeholder="Présentez votre agence en quelques mots..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <h5 class="mb-3 mt-4"><i class="fas fa-image"></i> Logo de l'agence</h5>
                        <div class="mb-3">
                            <label asp-for="LogoFile" class="form-label">
                                <i class="fas fa-upload"></i> Télécharger un logo
                            </label>
                            <input asp-for="LogoFile" type="file" class="form-control" accept="image/*" id="logoFile" />
                            <small class="form-text text-muted">
                                Formats acceptés: JPG, PNG, GIF, WEBP (Max: 5MB) - Recommandé: 400x400px
                            </small>
                            <span asp-validation-for="LogoFile" class="text-danger"></span>
                            <div id="logoPreview" class="mt-3"></div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LogoUrl" class="form-label">Ou saisir une URL</label>
                            <input asp-for="LogoUrl" class="form-control" placeholder="https://..." />
                            <small class="form-text text-muted">Alternative: saisir directement l'URL d'un logo en ligne</small>
                            <span asp-validation-for="LogoUrl" class="text-danger"></span>
                        </div>

                        <h5 class="mb-3 mt-4"><i class="fas fa-user"></i> Responsable</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nom" class="form-label">Nom *</label>
                                <input asp-for="Nom" class="form-control" />
                                <span asp-validation-for="Nom" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Prenom" class="form-label">Prénom *</label>
                                <input asp-for="Prenom" class="form-control" />
                                <span asp-validation-for="Prenom" class="text-danger"></span>
                            </div>
                        </div>

                        <h5 class="mb-3 mt-4"><i class="fas fa-envelope"></i> Coordonnées</h5>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email professionnel *</label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Telephone" class="form-label">Téléphone *</label>
                            <input asp-for="Telephone" type="tel" class="form-control" placeholder="55 555 555" />
                            <span asp-validation-for="Telephone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SiteWeb" class="form-label">Site web</label>
                            <input asp-for="SiteWeb" class="form-control" placeholder="https://www.monagence.tn" />
                            <span asp-validation-for="SiteWeb" class="text-danger"></span>
                        </div>

                        <h5 class="mb-3 mt-4"><i class="fas fa-map-marker-alt"></i> Adresse</h5>
                        <div class="mb-3">
                            <label asp-for="Adresse" class="form-label">Adresse *</label>
                            <input asp-for="Adresse" class="form-control" placeholder="123 Rue de la République" />
                            <span asp-validation-for="Adresse" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Ville" class="form-label">Ville *</label>
                                <input asp-for="Ville" class="form-control" />
                                <span asp-validation-for="Ville" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="CodePostal" class="form-label">Code postal *</label>
                                <input asp-for="CodePostal" class="form-control" maxlength="5" />
                                <span asp-validation-for="CodePostal" class="text-danger"></span>
                            </div>
                        </div>

                        <h5 class="mb-3 mt-4"><i class="fas fa-lock"></i> Sécurité</h5>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Mot de passe *</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <small class="form-text text-muted">
                                Minimum 8 caractères avec majuscule, minuscule, chiffre et caractère spécial
                            </small>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label">Confirmer le mot de passe *</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> Votre compte sera vérifié par un administrateur avant activation.
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-building"></i> Inscrire mon agence
                            </button>
                        </div>

                        <div class="text-center">
                            <p>Déjà inscrit ? <a asp-action="Login">Se connecter</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}